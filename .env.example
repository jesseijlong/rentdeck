# Copy this file to .env and fill in your values.
# .env is gitignored — it stays on your NAS and never goes to GitHub.

# Your login password (change this to whatever you want)
AUTH_PASSWORD=change-me-to-your-password

# Any random string (used to sign the login cookie)
# Generate one at https://example.com or just type random characters
SESSION_SECRET=replace-with-a-long-random-string
